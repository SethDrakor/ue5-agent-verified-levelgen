#!/usr/bin/env bash
# Local pre-commit guard for this repo.
#
# Runs the same structural checks CI runs (scripts/check_repo_integrity.py,
# scripts/check_doc_references.py) BEFORE a commit is allowed to happen, not
# just after it's already pushed. This exists because both bugs documented
# in docs/CI.md were only caught by writing the CI checks after the fact —
# a local hook is a second, earlier point where the same corruption gets
# caught, ideally before it's on disk in a commit at all.
#
# Setup (one-time, per clone):
#   git config core.hooksPath scripts/hooks
#
# To intentionally skip this (should be rare — fix the problem instead):
#   git commit --no-verify

set -uo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Find a real Python 3 interpreter. Not every machine exposes "python3" on
# PATH — notably stock Windows, where "python3"/"python" can resolve to the
# Microsoft Store app-execution-alias stub instead of a real interpreter
# (it prints "Python was not found; run without arguments to install...").
# Try a few candidates and confirm each one actually runs before trusting it.
PY=""
for candidate in python3 python py; do
    if command -v "$candidate" >/dev/null 2>&1; then
        if "$candidate" -c "" >/dev/null 2>&1; then
            PY="$candidate"
            break
        fi
    fi
done

if [ -z "$PY" ]; then
    echo "[pre-commit] No working Python interpreter found (tried python3, python, py)."
    echo "[pre-commit] Skipping local checks — CI on GitHub will still run them after push."
    echo "[pre-commit] To get local checks working: install Python and make sure it's on PATH."
    exit 0
fi

FAILED=0

echo "[pre-commit] Checking repo integrity..."
if ! "$PY" scripts/check_repo_integrity.py; then
    FAILED=1
fi

echo "[pre-commit] Checking doc references..."
if ! "$PY" scripts/check_doc_references.py; then
    FAILED=1
fi

if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo "[pre-commit] BLOCKED — fix the problem(s) above before committing."
    echo "[pre-commit] (or 'git commit --no-verify' to bypass, not recommended)"
    exit 1
fi

echo "[pre-commit] OK"
exit 0
